---
import Navbar from "@/components/layout/Navbar.astro";
import Footer from "@/components/layout/Footer.astro";
import ScrollToTop from "@/components/layout/ScrollToTop.astro";
import WhatsAppButton from "@/components/layout/WhatsAppButton.astro";
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "Fotografía profesional en San José, Costa Rica. Bodas, retratos, eventos y fotografía comercial. Photographic Images.",
  image = "/favicon.svg",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(image, Astro.url);

const schemaLD = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Photographic Images",
  "description": "Fotografía profesional de bodas, retratos, eventos y fotografía comercial en San José, Costa Rica.",
  "url": canonicalURL.href,
  "telephone": "+50685546933",
  "email": "isaiasdg14@hotmail.com",
  "priceRange": "$$",
  "image": socialImageURL.href,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Hatillo",
    "addressLocality": "San José",
    "addressRegion": "San José",
    "addressCountry": "CR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 9.9013,
    "longitude": -84.1083
  },
  "areaServed": {
    "@type": "GeoCircle",
    "geoMidpoint": { "@type": "GeoCoordinates", "latitude": 9.9013, "longitude": -84.1083 },
    "geoRadius": "30000"
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
    "opens": "08:00",
    "closes": "18:00"
  }
};
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title} | Photographic Images — San José, CR</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="keywords" content="fotógrafo San José Costa Rica, fotografía de bodas San José, fotografía profesional San José, fotografía de eventos San José, retratos profesionales San José, Photographic Images Costa Rica" />
    <meta name="author" content="Isaías Díaz García" />
    <meta name="robots" content="index, follow" />

    <!-- Geo — Hatillo, San José -->
    <meta name="geo.region"    content="CR-SJ" />
    <meta name="geo.placename" content="San José, Costa Rica" />
    <meta name="geo.position"  content="9.9013;-84.1083" />
    <meta name="ICBM"          content="9.9013, -84.1083" />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={socialImageURL} />
    <meta property="og:site_name"   content="Photographic Images" />
    <meta property="og:locale"      content="es_CR" />

    <!-- Twitter -->
    <meta property="twitter:card"        content="summary_large_image" />
    <meta property="twitter:url"         content={canonicalURL} />
    <meta property="twitter:title"       content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image"       content={socialImageURL} />

    <!-- Schema.org LocalBusiness -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaLD)} />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://res.cloudinary.com" />
    <link rel="preconnect" href="https://images.unsplash.com" />

    <!-- Fonts loaded via global.css -->

    <ClientRouter />
  </head>

  <!-- dark class is on <html>, so dark: variants always apply -->
  <body class="bg-black text-white antialiased">
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
    <ScrollToTop />
    <WhatsAppButton phoneNumber="+50685546933" />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
    scroll-padding-top: 80px;
  }

  body { min-height: 100vh; }

  ::-webkit-scrollbar       { width: 8px; }
  ::-webkit-scrollbar-track { background: #0d0d0d; }
  ::-webkit-scrollbar-thumb { background: #333; border-radius: 4px; }
  ::-webkit-scrollbar-thumb:hover { background: #555; }
</style>
