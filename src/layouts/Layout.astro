---
import Navbar from "@/components/layout/Navbar.astro";
import Footer from "@/components/layout/Footer.astro";
import ScrollToTop from "@/components/layout/ScrollToTop.astro";
import WhatsAppButton from "@/components/layout/WhatsAppButton.astro";
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
  image?: string;
  preloadImage?: string;
  preloadImageSrcset?: string;
  preloadImageSizes?: string;
}

const {
  title,
  description = "Fotógrafo profesional en San José con cobertura en todo Costa Rica. Bodas, retratos, eventos, bautizos y sacramentos. Isaías Díaz — Photographic Chagui.",
  image = "https://res.cloudinary.com/daqragn9m/image/upload/w_1200,h_630,c_fill,g_face,q_auto/v1782781402/libreria-chagui-sobre-nosotros_euzjwr.jpg",
  preloadImage,
  preloadImageSrcset,
  preloadImageSizes,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = image.startsWith("http") ? new URL(image) : new URL(image, Astro.url);

const schemaLD = {
  "@context": "https://schema.org",
  "@type": ["ProfessionalService", "LocalBusiness"],
  "name": "Photographic Chagui",
  "description": "Fotografía profesional de bodas, retratos, eventos, bautizos y sacramentos en Costa Rica.",
  "url": canonicalURL.href,
  "telephone": "+50685546933",
  "email": "isaiasdg14@hotmail.com",
  "priceRange": "$$",
  "image": socialImageURL.href,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "San José",
    "addressLocality": "San José",
    "addressRegion": "San José",
    "addressCountry": "CR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 9.9013,
    "longitude": -84.1083
  },
  "areaServed": [
    { "@type": "City",    "name": "San José",    "sameAs": "https://www.wikidata.org/wiki/Q3236" },
    { "@type": "State",   "name": "Guanacaste",  "containedInPlace": { "@type": "Country", "name": "Costa Rica" } },
    { "@type": "Country", "name": "Costa Rica",  "sameAs": "https://www.wikidata.org/wiki/Q800" }
  ],
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
    "opens": "08:00",
    "closes": "18:00"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": 5,
    "bestRating": 5,
    "worstRating": 1,
    "ratingCount": 4
  }
};
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/jpeg" href="https://res.cloudinary.com/daqragn9m/image/upload/w_64,h_64,c_fill,g_face/v1782781402/libreria-chagui-sobre-nosotros_euzjwr.jpg" />
    <link rel="apple-touch-icon" href="https://res.cloudinary.com/daqragn9m/image/upload/w_180,h_180,c_fill,g_face/v1782781402/libreria-chagui-sobre-nosotros_euzjwr.jpg" />

    {preloadImage && (
      <link
        rel="preload"
        as="image"
        href={preloadImage}
        imagesrcset={preloadImageSrcset}
        imagesizes={preloadImageSizes}
        fetchpriority="high"
      />
    )}

    <!-- SEO -->
    <title>{title} | Photographic Chagui — San José, CR</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="keywords" content="fotógrafo Costa Rica, fotógrafo San José Costa Rica, fotografía de bodas Costa Rica, fotógrafo de bodas Guanacaste, fotógrafo bodas Manuel Antonio, fotógrafo bodas Monteverde, retratos profesionales Costa Rica, fotografía de eventos Costa Rica, fotógrafo bautizos Costa Rica, fotografía primera comunión San José, fotógrafo confirmación Costa Rica, fotógrafo sacramentos Costa Rica, fotógrafo San José, fotógrafo profesional San José, Photographic Chagui" />
    <meta name="author" content="Isaías Díaz García" />
    <meta name="robots" content="index, follow" />

    <!-- Geo — San José -->
    <meta name="geo.region"    content="CR-SJ" />
    <meta name="geo.placename" content="San José, Costa Rica" />
    <meta name="geo.position"  content="9.9013;-84.1083" />
    <meta name="ICBM"          content="9.9013, -84.1083" />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={socialImageURL} />
    <meta property="og:site_name"   content="Photographic Chagui" />
    <meta property="og:locale"      content="es_CR" />

    <!-- Twitter -->
    <meta property="twitter:card"        content="summary_large_image" />
    <meta property="twitter:url"         content={canonicalURL} />
    <meta property="twitter:title"       content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image"       content={socialImageURL} />

    <!-- Schema.org LocalBusiness -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaLD)} />

    <!-- Preconnect + Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://res.cloudinary.com" />
    <link rel="preconnect" href="https://images.unsplash.com" />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Work+Sans:wght@300;400;500;600;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Work+Sans:wght@300;400;500;600;700&display=swap"
      />
    </noscript>

    <ClientRouter />
  </head>

  <!-- dark class is on <html>, so dark: variants always apply -->
  <body class="bg-black text-white antialiased">
    <div id="page-progress" aria-hidden="true"></div>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
    <ScrollToTop />
    <WhatsAppButton phoneNumber="+50685546933" />
    <div id="cursor-dot" aria-hidden="true"></div>
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
    scroll-padding-top: 80px;
  }

  body { min-height: 100vh; }

  ::-webkit-scrollbar       { width: 8px; }
  ::-webkit-scrollbar-track { background: #0d0d0d; }
  ::-webkit-scrollbar-thumb { background: #333; border-radius: 4px; }
  ::-webkit-scrollbar-thumb:hover { background: #555; }

  /* ── Page transition progress bar ── */
  #page-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    z-index: 9999;
    pointer-events: none;
    background: white;
    transform-origin: left center;
    transform: scaleX(0);
    opacity: 0;
  }

  #page-progress.is-loading {
    opacity: 0.75;
    animation: progress-advance 1.8s cubic-bezier(0.1, 0.05, 0.3, 1) forwards;
  }

  #page-progress.is-done {
    animation: none;
    transform: scaleX(1);
    opacity: 0;
    transition: opacity 0.35s ease 0.05s;
  }

  @keyframes progress-advance {
    0%   { transform: scaleX(0.04); }
    40%  { transform: scaleX(0.55); }
    70%  { transform: scaleX(0.75); }
    100% { transform: scaleX(0.88); }
  }

  @media (prefers-reduced-motion: reduce) {
    #page-progress { display: none; }
  }

  /* ── Custom cursor ring (pointer:fine only) ── */
  #cursor-dot {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    pointer-events: none;
    z-index: 99999;
    translate: -50% -50%;
    background: rgba(255, 255, 255, 0.06);
    border: 1.5px solid rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(1px);
    transition: opacity 0.3s, width 0.22s cubic-bezier(0.34, 1.56, 0.64, 1), height 0.22s cubic-bezier(0.34, 1.56, 0.64, 1), border-color 0.22s, background 0.22s;
    will-change: transform;
  }

  #cursor-dot.cursor-grow {
    width: 44px;
    height: 44px;
    border-color: rgba(255, 255, 255, 0.9);
    background: rgba(255, 255, 255, 0.1);
  }

  @media (pointer: fine) {
    #cursor-dot { display: block; }
  }

  @media (prefers-reduced-motion: reduce) {
    #cursor-dot { display: none !important; }
  }
</style>

<script>
  const bar = document.getElementById('page-progress')!

  document.addEventListener('astro:before-preparation', () => {
    bar.classList.remove('is-done')
    void bar.offsetWidth // force reflow to restart animation
    bar.classList.add('is-loading')
  })

  document.addEventListener('astro:page-load', () => {
    bar.classList.remove('is-loading')
    bar.classList.add('is-done')
    setTimeout(() => bar.classList.remove('is-done'), 400)
  })
</script>

<script>
  // Custom cursor ring — smooth lerp follow, pointer:fine only.
  // Single global rAF loop + delegated listeners so it survives Astro page swaps
  // without restarting (the #cursor-dot node is re-created on every navigation).
  function initCursor() {
    if ((window as any).__cursorReady) return
    if (!window.matchMedia('(pointer: fine)').matches) return
    ;(window as any).__cursorReady = true

    let tx = -200, ty = -200
    let cx = -200, cy = -200

    const HOVER_SELECTOR = 'a, button, [role="button"], input, select, textarea, label'

    document.addEventListener('mousemove', (e) => {
      tx = e.clientX
      ty = e.clientY
    }, { passive: true })

    document.addEventListener('mouseleave', () => {
      const dot = document.getElementById('cursor-dot')
      if (dot) dot.style.opacity = '0'
    })
    document.addEventListener('mouseenter', () => {
      const dot = document.getElementById('cursor-dot')
      if (dot) dot.style.opacity = '1'
    })

    document.addEventListener('mouseover', (e) => {
      if ((e.target as Element)?.closest?.(HOVER_SELECTOR)) {
        document.getElementById('cursor-dot')?.classList.add('cursor-grow')
      }
    })
    document.addEventListener('mouseout', (e) => {
      if ((e.target as Element)?.closest?.(HOVER_SELECTOR)) {
        document.getElementById('cursor-dot')?.classList.remove('cursor-grow')
      }
    })

    ;(function loop() {
      cx += (tx - cx) * 0.1
      cy += (ty - cy) * 0.1
      const dot = document.getElementById('cursor-dot')
      if (dot) dot.style.transform = `translate(${cx}px, ${cy}px)`
      requestAnimationFrame(loop)
    })()
  }

  initCursor()
  document.addEventListener('astro:page-load', initCursor)
</script>
