---
import NavbarMobile from "@/components/react/NavbarMobile";
import { cldOptimize } from "@/lib/cloudinary";
import { services } from "@/data/services";

const NAV_LINKS = [
  { href: "/servicios/", label: "Servicios" },
  { href: "/sobre-mi/",  label: "Sobre mí"  },
  { href: "/paquetes/",  label: "Paquetes"  },
  { href: "/#contacto",  label: "Contacto"  },
];

const activeServices = services
  .filter((s) => s.is_active)
  .sort((a, b) => a.order - b.order);

const currentPath = Astro.url.pathname;
---

<nav
  id="main-navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-black/90 backdrop-blur-md border-b border-white/5"
>
  <div class="container mx-auto px-4 lg:px-8">
    <div class="flex items-center justify-between h-20">

      <!-- Logo -->
      <a
        href="/"
        data-astro-prefetch
        class="group focus-visible:outline-2 focus-visible:outline-white"
        aria-label="Photographic Chagui — Inicio"
      >
        <img
          src={cldOptimize(
            "https://res.cloudinary.com/daqragn9m/image/upload/v1782781402/libreria-chagui-sobre-nosotros_euzjwr.jpg",
            112,
            112
          )}
          alt="Photographic Chagui"
          class="h-14 w-14 rounded-full object-cover object-top border border-white/20 opacity-90 group-hover:opacity-100 transition-opacity duration-200"
          width="56"
          height="56"
        />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8" aria-label="Navegación principal">
        {NAV_LINKS.map(({ href, label }) =>
          label === "Servicios" ? (
            <div class="relative group">
              <a
                href={href}
                data-astro-prefetch
                class="flex items-center gap-1.5 text-base text-white/70 hover:text-white transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-white"
                style="font-family: 'Playfair Display', Georgia, serif; font-style: italic;"
              >
                {label}
                <svg
                  class="w-3 h-3 mt-0.5 transition-transform duration-200 group-hover:rotate-180"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
                </svg>
              </a>

              <div class="absolute top-full left-0 pt-5 w-80 opacity-0 invisible -translate-y-1 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 group-focus-within:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 transition-all duration-300 ease-out">
                <div class="bg-black/95 backdrop-blur-md border border-white/10 shadow-xl shadow-black/50">
                  <ul>
                    {activeServices.map((service, i) => (
                      <li class={i > 0 ? "border-t border-white/8" : ""}>
                        <a
                          href={`/servicios/${service.slug}/`}
                          data-astro-prefetch
                          class="group/item flex items-center justify-between gap-4 px-7 py-4 text-white/75 hover:text-white transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-white focus-visible:-outline-offset-2"
                        >
                          <span
                            class="text-[1.05rem] transition-transform duration-200 group-hover/item:translate-x-1"
                            style="font-family: 'Playfair Display', Georgia, serif; font-style: italic;"
                          >
                            {service.title}
                          </span>
                          <span
                            class="w-3 h-px bg-white/0 group-hover/item:bg-white/50 transition-colors duration-200 shrink-0"
                            aria-hidden="true"
                          />
                        </a>
                      </li>
                    ))}
                  </ul>
                  <a
                    href="/servicios/"
                    data-astro-prefetch
                    class="group/cta flex items-center justify-between gap-2 px-7 py-4 border-t border-white/10 text-[0.7rem] uppercase tracking-[0.2em] text-white/50 hover:text-white transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-white focus-visible:-outline-offset-2"
                  >
                    Ver todos los servicios
                    <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover/cta:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          ) : (
            <a
              href={href}
              data-astro-prefetch
              class="text-base text-white/70 hover:text-white transition-colors duration-200 relative group focus-visible:outline-2 focus-visible:outline-white"
              style="font-family: 'Playfair Display', Georgia, serif; font-style: italic;"
            >
              {label}
              <span
                class="absolute -bottom-0.5 left-0 w-full h-px bg-white transition-transform duration-200 origin-left scale-x-0 group-hover:scale-x-100"
                aria-hidden="true"
              />
            </a>
          )
        )}
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden md:flex items-center">
        <a
          href="https://wa.me/50685546933"
          target="_blank"
          rel="noopener noreferrer"
          class="px-5 py-2.5 border border-white/30 text-white text-sm font-medium transition-all duration-300 hover:border-white hover:bg-white hover:text-black focus-visible:outline-2 focus-visible:outline-white"
        >
          WhatsApp
        </a>
      </div>

      <!-- Mobile -->
      <div class="md:hidden">
        <NavbarMobile client:media="(max-width: 767px)" navLinks={NAV_LINKS} currentPath={currentPath} />
      </div>

    </div>
  </div>
</nav>

<!-- Spacer -->
<div class="h-20" aria-hidden="true"></div>

<script>
  function initNavbar() {
    const navbar = document.getElementById('main-navbar')
    if (!navbar) return

    const handleScroll = () => {
      if (window.pageYOffset > 10) {
        navbar.classList.add('shadow-lg', 'shadow-black/50')
      } else {
        navbar.classList.remove('shadow-lg', 'shadow-black/50')
      }
    }

    window.addEventListener('scroll', handleScroll, { passive: true })
    handleScroll()
  }

  initNavbar()
  document.addEventListener('astro:page-load', initNavbar)
</script>
