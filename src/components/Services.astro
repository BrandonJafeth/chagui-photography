---
// TODO: migrar a Supabase — tabla services
import { services } from '@/data/services'
---

<section id="servicios" class="py-24 bg-black">
  <div class="max-w-6xl mx-auto px-4">

    {/* Título */}
    <div class="mb-16 text-center">
      <h2 class="text-3xl md:text-4xl text-white mb-3">
        Servicios
      </h2>
      <div class="w-12 h-px bg-white/40 mx-auto mb-5"></div>
      <p class="text-white/50 max-w-xl mx-auto">
        Fotografía profesional adaptada a cada momento y cada necesidad.
      </p>
    </div>

    {/* Bloques alternados imagen / texto */}
    <div class="space-y-0">
      {services.filter(s => s.is_active).map((service, i) => {
        const isEven = i % 2 === 0
        return (
          <div class:list={[
            'grid grid-cols-1 md:grid-cols-2 group',
            i < services.length - 1 ? 'border-b border-white/8' : ''
          ]}>

            {/* Imagen */}
            <div class:list={[
              'relative overflow-hidden aspect-video md:aspect-auto md:min-h-80',
              isEven ? 'md:order-1' : 'md:order-2'
            ]}>
              <img
                src={service.image}
                alt={service.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
                width="600"
                height="400"
              />
              <div class="absolute inset-0 bg-black/20 group-hover:bg-black/10 transition-colors duration-500"></div>
            </div>

            {/* Texto */}
            <div class:list={[
              'flex flex-col justify-center px-8 py-12 md:py-16 bg-black',
              isEven ? 'md:order-2' : 'md:order-1'
            ]}>
              <h3 class="text-xl md:text-2xl text-white mb-4">
                {service.title}
              </h3>
              <div class="w-8 h-px bg-white/30 mb-5"></div>
              <p class="text-white/60 leading-relaxed mb-6 text-sm md:text-base">
                {service.description}
              </p>
              <ul class="space-y-2 mb-8">
                {service.features.map(f => (
                  <li class="flex items-start gap-3 text-sm text-white/50">
                    <span class="mt-1.5 w-1 h-1 rounded-full bg-white/40 shrink-0"></span>
                    {f}
                  </li>
                ))}
              </ul>
              <a
                href={`/#contacto`}
                class="self-start inline-flex items-center gap-2 px-6 py-3 border border-white/30 text-white text-sm uppercase tracking-wider transition-all duration-300 hover:border-white hover:bg-white hover:text-black min-h-11 focus-visible:outline-2 focus-visible:outline-white"
              >
                Cotizar
                <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>

          </div>
        )
      })}
    </div>

  </div>
</section>
