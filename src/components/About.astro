---
// TODO: migrar a Supabase — tabla site_content (keys: about_*)
import { getContent } from '@/data/site-content'

const title     = getContent('about_title')
const subtitle  = getContent('about_subtitle')
const text      = getContent('about_text')
const imageUrl  = getContent('about_image_url')
const imageAlt  = 'Photographic Chagui — fotógrafo profesional en San José, Costa Rica'

const paragraphs = text.split('\n\n').filter(Boolean)
---

<section
  id="sobre-mi"
  class="py-24 px-4 bg-black"
>
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">

      {/* ── Imagen polaroid ── */}
      <div class="flex justify-center lg:justify-start">
        <div class="polaroid-stack w-full max-w-xs sm:max-w-sm">
          <div class="polaroid-card">
            <div class="polaroid-inner">
              <img
                src={imageUrl}
                alt={imageAlt}
                class="w-full h-full object-cover object-top"
                loading="lazy"
                width="400"
                height="500"
              />
            </div>
          </div>
          <div class="polaroid-back" aria-hidden="true"></div>
        </div>
      </div>

      {/* ── Texto ── */}
      <div>
        <div class="mb-8">
          <h2 class="text-3xl md:text-4xl text-white mb-3">
            {title}
          </h2>
          <div class="w-12 h-px bg-white/40"></div>
        </div>

        {subtitle && (
          <p class="text-lg text-white/60 mb-6 leading-relaxed">{subtitle}</p>
        )}

        {/* Stats strip */}
        <div class="grid grid-cols-3 gap-4 py-7 border-y border-white/10 mb-8">
          <div class="text-center">
            <p
              class="text-2xl md:text-3xl text-white font-bold"
              style="font-family: 'Playfair Display', Georgia, serif; font-style: italic;"
            >
              80<span class="text-white/35">+</span>
            </p>
            <p class="text-[0.65rem] text-white/40 uppercase tracking-wider mt-1">Eventos</p>
          </div>
          <div class="text-center border-x border-white/10">
            <p
              class="text-2xl md:text-3xl text-white font-bold"
              style="font-family: 'Playfair Display', Georgia, serif; font-style: italic;"
            >
              5<span class="text-white/35">★</span>
            </p>
            <p class="text-[0.65rem] text-white/40 uppercase tracking-wider mt-1">Calificación</p>
          </div>
          <div class="text-center">
            <p
              class="text-2xl md:text-3xl text-white font-bold"
              style="font-family: 'Playfair Display', Georgia, serif; font-style: italic;"
            >
              25<span class="text-white/35">+</span>
            </p>
            <p class="text-[0.65rem] text-white/40 uppercase tracking-wider mt-1">Años</p>
          </div>
        </div>

        <div class="space-y-4">
          {paragraphs.map((p) => (
            <p class="text-white/70 leading-relaxed text-base md:text-[1.05rem]">{p}</p>
          ))}
        </div>

        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a
            href="/#contacto"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white text-black font-semibold text-sm uppercase tracking-wider transition-all duration-200 hover:bg-white/90 min-h-11 focus-visible:outline-2 focus-visible:outline-white"
          >
            Hablemos de tu proyecto
          </a>
          <a
            href="/#servicios"
            class="inline-flex items-center justify-center px-6 py-3 border border-white/30 text-white/80 text-sm uppercase tracking-wider transition-all duration-300 hover:border-white hover:text-white min-h-11"
          >
            Ver servicios →
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .polaroid-stack {
    position: relative;
  }

  .polaroid-card {
    position: relative;
    z-index: 1;
    width: 100%;
    aspect-ratio: 4 / 5;
    background: #0d0d0d;
    border: 3px solid #fff;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.75);
    transition: transform 0.3s ease;
  }

  .polaroid-inner {
    width: 100%;
    height: 100%;
    padding: 4%;
    padding-bottom: 13%;
    background: #0d0d0d;
  }

  .polaroid-inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .polaroid-back {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    aspect-ratio: 4 / 5;
    background: #1a1a1a;
    border: 3px solid rgba(255, 255, 255, 0.55);
    transform: rotate(4deg) translateY(-2%);
    z-index: 0;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  }

  .polaroid-stack:hover .polaroid-card {
    transform: rotate(-2deg);
  }
</style>
