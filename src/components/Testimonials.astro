---
// TODO: migrar a Supabase — tabla testimonials
import { testimonials } from '@/data/testimonials'

const visible = testimonials.filter(t => t.is_visible).sort((a, b) => a.order - b.order)
---

{visible.length > 0 && (
<section id="testimonios" class="py-24 bg-[#070707]">
  <div class="max-w-6xl mx-auto px-4">

    <div class="mb-14 text-center">
      <h2 class="text-3xl md:text-4xl text-white mb-3">
        Testimonios
      </h2>
      <div class="w-12 h-px bg-white/40 mx-auto"></div>
    </div>

    {/* Drag-scroll horizontal */}
    <div
      id="testimonials-scroll"
      class="overflow-x-auto pb-6 cursor-grab active:cursor-grabbing select-none"
      style="-ms-overflow-style:none; scrollbar-width:none;"
    >
      <div class="flex gap-5 px-1 min-w-max">
        {visible.map((t) => (
          <article class="w-[min(calc(100vw-2.5rem),380px)] shrink-0 bg-white/2.5 p-8 relative overflow-hidden transition-all duration-300 hover:bg-white/5 hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/60">

            {/* Decorative quote */}
            <span
              class="absolute top-0 right-4 text-white/4.5 select-none pointer-events-none leading-none"
              style="font-family: 'Playfair Display', Georgia, serif; font-size: 8rem; font-style: italic; line-height: 0.9;"
              aria-hidden="true"
            >&ldquo;</span>

            {/* Stars */}
            <div class="flex gap-1 mb-6" aria-label={`${t.rating} de 5 estrellas`}>
              {Array.from({ length: 5 }, (_, i) => (
                <svg
                  class:list={['w-3.5 h-3.5', i < t.rating ? 'text-white/60' : 'text-white/15']}
                  fill="currentColor"
                  viewBox="0 0 20 20"
                  aria-hidden="true"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            {/* Quote text */}
            <blockquote class="text-white/70 text-sm leading-[1.85] mb-8 relative z-10">
              "{t.text}"
            </blockquote>

            {/* Author */}
            <footer class="flex items-center gap-4">
              <div class="w-11 h-11 rounded-full bg-white/8 border border-white/15 flex items-center justify-center shrink-0">
                <span
                  class="text-white/70 text-base font-semibold"
                  style="font-family: 'Playfair Display', Georgia, serif; font-style: italic;"
                >
                  {t.client_name.charAt(0)}
                </span>
              </div>
              <div>
                <p class="text-white text-sm font-medium">{t.client_name}</p>
                {t.position && <p class="text-white/35 text-xs mt-0.5">{t.position}</p>}
              </div>
            </footer>

          </article>
        ))}
      </div>
    </div>

  </div>
</section>
)}

<style>
  #testimonials-scroll::-webkit-scrollbar { display: none; }
</style>

<script>
  function initTestimonialsScroll() {
    const el = document.getElementById('testimonials-scroll')
    if (!el) return
    let isDown = false, startX = 0, scrollLeft = 0

    el.addEventListener('mousedown', (e) => {
      isDown = true
      startX = e.pageX - el.offsetLeft
      scrollLeft = el.scrollLeft
    })
    el.addEventListener('mouseleave', () => { isDown = false })
    el.addEventListener('mouseup',    () => { isDown = false })
    el.addEventListener('mousemove',  (e) => {
      if (!isDown) return
      e.preventDefault()
      el.scrollLeft = scrollLeft - (e.pageX - el.offsetLeft - startX) * 1.5
    })
  }

  initTestimonialsScroll()
  document.addEventListener('astro:page-load', initTestimonialsScroll)
</script>
