---
import { getTestimonials } from '@/lib/db'

const visible = await getTestimonials()
---

{visible.length > 0 && (
<section id="testimonios" class="py-24 bg-[#070707]">
  <div class="max-w-6xl mx-auto px-4">

    <div class="mb-14 text-center">
      <h2 class="text-3xl md:text-4xl text-white mb-3">
        Testimonios
      </h2>
      <div class="w-12 h-px bg-white/40 mx-auto"></div>
    </div>

    {/* Swipe hint — mobile only, fades after first scroll */}
    <p id="testimonials-hint" class="flex items-center justify-center gap-2 text-xs text-white/60 uppercase tracking-widest mb-6 sm:hidden transition-opacity duration-500">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
      Deslizá para ver más
    </p>

    {/* Drag-scroll horizontal */}
    <div
      id="testimonials-scroll"
      class="overflow-x-auto pb-4 cursor-grab active:cursor-grabbing select-none"
      style="-ms-overflow-style:none; scrollbar-width:none;"
    >
      <div class="flex gap-5 pl-4 pr-8 sm:px-1 min-w-max">
        {visible.map((t, idx) => (
          <article data-index={idx} class="w-[min(calc(100vw-5rem),380px)] sm:w-95 shrink-0 bg-white/2.5 p-8 relative overflow-hidden transition-all duration-300 hover:bg-white/5 hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/60 flex flex-col">

            {/* Decorative quote */}
            <span
              class="absolute top-0 right-4 text-white/4.5 select-none pointer-events-none leading-none"
              style="font-family: 'Playfair Display', Georgia, serif; font-size: 8rem; font-style: italic; line-height: 0.9;"
              aria-hidden="true"
            >&ldquo;</span>

            {/* Stars */}
            <div class="flex gap-1 mb-6" aria-label={`${t.rating} de 5 estrellas`}>
              {Array.from({ length: 5 }, (_, i) => (
                <svg
                  class:list={['w-3.5 h-3.5', i < t.rating ? 'text-white/60' : 'text-white/15']}
                  fill="currentColor"
                  viewBox="0 0 20 20"
                  aria-hidden="true"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            {/* Quote text */}
            <blockquote class="text-white/70 text-sm leading-[1.85] mb-8 relative z-10 flex-1">
              "{t.text}"
            </blockquote>

            {/* Author */}
            <footer class="flex items-center gap-4 mt-auto">
              <div class="w-11 h-11 rounded-full bg-white/8 border border-white/15 flex items-center justify-center shrink-0">
                <span
                  class="text-white/70 text-base font-semibold"
                  style="font-family: 'Playfair Display', Georgia, serif; font-style: italic;"
                >
                  {t.client_name.charAt(0)}
                </span>
              </div>
              <div>
                <p class="text-white text-sm font-medium">{t.client_name}</p>
                {t.position && <p class="text-white/60 text-xs mt-0.5">{t.position}</p>}
              </div>
            </footer>

          </article>
        ))}
      </div>
    </div>

    {/* Scroll dots — mobile only */}
    {visible.length > 1 && (
      <div id="testimonials-dots" class="flex justify-center gap-2 mt-6 sm:hidden" aria-hidden="true">
        {visible.map((_, i) => (
          <button
            class:list={['testimonial-dot w-1.5 h-1.5 rounded-full transition-all duration-300', i === 0 ? 'bg-white/70 w-4' : 'bg-white/20']}
            data-idx={i}
          />
        ))}
      </div>
    )}

  </div>
</section>
)}

<style>
  #testimonials-scroll::-webkit-scrollbar { display: none; }
</style>

<script>
  function initTestimonialsScroll() {
    const el = document.getElementById('testimonials-scroll')
    if (!el) return

    // Drag scroll
    let isDown = false, startX = 0, scrollLeft = 0
    el.addEventListener('mousedown', (e) => {
      isDown = true
      startX = e.pageX - el.offsetLeft
      scrollLeft = el.scrollLeft
    })
    el.addEventListener('mouseleave', () => { isDown = false })
    el.addEventListener('mouseup',    () => { isDown = false })
    el.addEventListener('mousemove',  (e) => {
      if (!isDown) return
      e.preventDefault()
      el.scrollLeft = scrollLeft - (e.pageX - el.offsetLeft - startX) * 1.5
    })

    // Dots + hint fade
    const dots   = document.querySelectorAll<HTMLElement>('.testimonial-dot')
    const hint   = document.getElementById('testimonials-hint')
    let hinted   = false

    function updateDots() {
      if (!el || !dots.length) return
      const articles = el.querySelectorAll<HTMLElement>('article')
      if (!articles.length) return
      const cardW  = articles[0].offsetWidth + 20 // gap-5 = 20px
      const active = Math.round(el.scrollLeft / cardW)
      dots.forEach((d, i) => {
        const isActive = i === active
        d.classList.toggle('bg-white/70', isActive)
        d.classList.toggle('w-4',         isActive)
        d.classList.toggle('bg-white/20', !isActive)
        d.classList.toggle('w-1.5',       !isActive)
      })
      if (!hinted && el.scrollLeft > 10 && hint) {
        hint.style.opacity = '0'
        hint.style.pointerEvents = 'none'
        hinted = true
      }
    }

    el.addEventListener('scroll', updateDots, { passive: true })
    updateDots()
  }

  initTestimonialsScroll()
  document.addEventListener('astro:page-load', initTestimonialsScroll)
</script>
