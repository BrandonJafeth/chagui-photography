---
// TODO: migrar a Supabase — tabla services
import { services } from '@/data/services'

const activeServices = services.filter(s => s.is_active).sort((a, b) => a.order - b.order)
---

<section id="servicios" class="py-24 bg-black">
  <div class="max-w-6xl mx-auto px-4">

    <div class="mb-14 flex items-end justify-between">
      <div>
        <h2 class="text-3xl md:text-4xl text-white mb-3">Servicios</h2>
        <div class="w-12 h-px bg-white/40"></div>
      </div>
      <a
        href="/servicios/"
        class="hidden sm:inline-flex items-center gap-2 text-sm text-white/40 hover:text-white transition-colors duration-200 uppercase tracking-wider focus-visible:outline-2 focus-visible:outline-white"
      >
        Ver todos
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    {/* Editorial magazine grid — alternating wide/narrow */}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-white/8">
      {activeServices.map((service, i) => {
        const isWide = i === 0 || i === 3
        return (
          <div
            class:list={[
              'group relative overflow-hidden h-60 sm:h-72 lg:h-85',
              isWide ? 'lg:col-span-2' : '',
            ]}
          >
            {/* Image */}
            <img
              src={service.image}
              alt={service.title}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 brightness-50 group-hover:brightness-75"
              loading="lazy"
              width="800"
              height="500"
            />

            {/* Gradient */}
            <div
              class="absolute inset-0 bg-linear-to-t from-black/90 via-black/25 to-black/10 group-hover:from-black/80 transition-all duration-500"
              aria-hidden="true"
            />

            {/* Top-right arrow — appears on hover */}
            <a
              href="/#contacto"
              class="absolute top-4 right-5 p-2 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-1 group-hover:translate-x-0 focus-visible:outline-2 focus-visible:outline-white"
              aria-label={`Cotizar ${service.title}`}
            >
              <svg class="w-5 h-5 text-white/80" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7v10" />
              </svg>
            </a>

            {/* Bottom text */}
            <div class="absolute bottom-0 left-0 right-0 p-6 lg:p-8">
              <h3 class="text-lg lg:text-xl text-white mb-2 transition-transform duration-300 group-hover:-translate-y-1">
                {service.title}
              </h3>
              <p class="text-white/60 text-xs leading-relaxed max-w-sm opacity-0 translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 line-clamp-2">
                {service.description}
              </p>
            </div>

          </div>
        )
      })}
    </div>

    {/* Mobile CTA */}
    <div class="mt-10 text-center sm:hidden">
      <a
        href="/servicios/"
        class="inline-flex items-center gap-2 px-7 py-3 border border-white/30 text-white text-sm uppercase tracking-wider transition-all duration-300 hover:border-white hover:bg-white hover:text-black min-h-11 focus-visible:outline-2 focus-visible:outline-white"
      >
        Ver todos los servicios
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

  </div>
</section>
