---
import { getPackages } from '@/lib/db'

interface Props {
  preview?: boolean
  showHeader?: boolean
}
const { preview = false, showHeader = true } = Astro.props

const pkgs = await getPackages()
---

<section id="paquetes" class:list={['bg-[#070707]', showHeader ? 'py-16 md:py-24' : 'pt-10 md:pt-14 pb-16 md:pb-24']}>
  <div class="max-w-6xl mx-auto px-4">

    {showHeader && (
      <div class="mb-8 md:mb-14 flex items-end justify-between">
        <div>
          <h2 class="text-3xl md:text-4xl text-white mb-3">Paquetes</h2>
          <div class="w-12 h-px bg-white/40"></div>
        </div>
        {preview && (
          <a
            href="/paquetes/"
            class="hidden sm:inline-flex items-center gap-2 text-sm text-white/60 hover:text-white transition-colors duration-200 uppercase tracking-wider focus-visible:outline-2 focus-visible:outline-white"
          >
            Ver todos
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        )}
      </div>
    )}

    <div class:list={[
      'grid gap-px bg-white/8',
      pkgs.length === 1 ? 'grid-cols-1 max-w-sm' :
      pkgs.length >= 3 ? 'grid-cols-1 md:grid-cols-3' :
                         'grid-cols-1 md:grid-cols-2',
    ]}>
      {pkgs.map((pkg) => {
        const isFeatured = pkg.is_featured === true
        return (
          <div
            class:list={[
              'relative flex flex-col px-6 py-8 md:px-8 md:py-10 overflow-hidden transition-all duration-500 group pkg-card',
              isFeatured ? 'pkg-featured' : 'bg-[#070707] pkg-plain',
            ]}
            style={isFeatured
              ? 'background: radial-gradient(ellipse 150% 55% at 50% -5%, rgba(255,255,255,0.07) 0%, transparent 65%), #0a0a0a;'
              : undefined}
          >

            {/* Left border reveal — editorial accent */}
            <div class="pkg-left-bar" aria-hidden="true" />

            {/* Top accent line */}
            <div
              class:list={['pkg-accent-line w-full h-px mb-6 md:mb-10 transition-colors duration-500', isFeatured ? 'bg-white/50' : 'bg-white/12']}
              aria-hidden="true"
            />

            <div class="flex flex-col flex-1">

              <h4
                class:list={[
                  'leading-tight mb-3',
                  isFeatured ? 'text-3xl text-white' : 'text-2xl text-white/85',
                ]}
              >
                {pkg.name}
              </h4>

              <p
                class:list={[
                  'text-sm mb-8 leading-relaxed',
                  isFeatured ? 'text-white/70' : 'text-white/60',
                ]}
              >
                {pkg.description}
              </p>

              <ul class="space-y-3 mb-10 flex-1">
                {pkg.includes.map(item => (
                  <li class="flex items-start gap-3 text-sm">
                    <svg
                      class:list={['w-3.5 h-3.5 mt-0.5 shrink-0', isFeatured ? 'text-white/50' : 'text-white/25']}
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class:list={[isFeatured ? 'text-white/80' : 'text-white/55']}>
                      {item}
                    </span>
                  </li>
                ))}
              </ul>

              <a
                href={`https://wa.me/50685546933?text=${encodeURIComponent(`Hola Isaías, me interesa el paquete *${pkg.name}*.`)}`}
                target="_blank"
                rel="noopener noreferrer"
                class:list={[
                  'text-center px-5 py-3 text-sm uppercase tracking-wider font-semibold transition-all duration-300 min-h-11 flex items-center justify-center focus-visible:outline-2 focus-visible:outline-white',
                  isFeatured
                    ? 'bg-white text-black hover:bg-white/90'
                    : 'border border-white/20 text-white/75 hover:border-white/50 hover:text-white',
                ]}
              >
                Consultar
              </a>

            </div>
          </div>
        )
      })}
    </div>

    {/* Mobile only — ver todos */}
    {preview && (
      <div class="mt-8 text-center sm:hidden">
        <a
          href="/paquetes/"
          class="inline-flex items-center gap-2 px-7 py-3 border border-white/30 text-white text-sm uppercase tracking-wider transition-all duration-300 hover:border-white hover:bg-white hover:text-black min-h-11 focus-visible:outline-2 focus-visible:outline-white"
        >
          Ver todos los paquetes
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    )}

    {/* Página completa — CTA personalizado */}
    {!preview && (
      <div class="mt-16 py-12 border-t border-white/8 text-center">
        <p class="text-white/60 text-sm mb-6">¿Tenés algo en mente que no está listado?</p>
        <a
          href={`https://wa.me/50685546933?text=${encodeURIComponent('Hola Isaías, me gustaría consultar sobre un paquete personalizado.')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-3.5 bg-white text-black text-sm uppercase tracking-wider font-semibold transition-all duration-200 hover:bg-white/90 min-h-11 focus-visible:outline-2 focus-visible:outline-white"
        >
          Consultar paquete personalizado
        </a>
      </div>
    )}

  </div>
</section>

<style>
  /* ── Left border reveal ── */
  .pkg-left-bar {
    position: absolute;
    left: 0;
    top: 0;
    width: 2px;
    height: 100%;
    background: rgba(255, 255, 255, 0);
    transition: background 0.5s ease;
  }

  /* ── Non-featured hover ── */
  .pkg-plain:hover {
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.07),
      0 20px 60px rgba(0, 0, 0, 0.7);
  }
  .pkg-plain:hover .pkg-left-bar {
    background: rgba(255, 255, 255, 0.22);
  }
  .pkg-plain:hover .pkg-accent-line {
    background: rgba(255, 255, 255, 0.4) !important;
  }

  /* ── Featured hover ── */
  .pkg-featured:hover {
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.12),
      0 24px 80px rgba(0, 0, 0, 0.8),
      0 0 60px rgba(255, 255, 255, 0.03);
    filter: brightness(1.12);
  }
  .pkg-featured:hover .pkg-left-bar {
    background: rgba(255, 255, 255, 0.35);
  }
  .pkg-featured:hover .pkg-accent-line {
    background: rgba(255, 255, 255, 0.75) !important;
  }
</style>
