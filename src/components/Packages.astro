---
// TODO: migrar a Supabase — tabla packages
import { packages } from '@/data/packages'
import { services } from '@/data/services'

interface Props {
  preview?: boolean
}
const { preview = false } = Astro.props

let byService = services.map(s => ({
  service: s,
  pkgs: packages.filter(p => p.service_id === s.id && p.is_active).sort((a, b) => a.order - b.order),
})).filter(g => g.pkgs.length > 0)

if (preview) byService = byService.slice(0, 1)
---

<section id="paquetes" class="py-24 bg-[#070707]">
  <div class="max-w-6xl mx-auto px-4">

    <div class="mb-16 flex items-end justify-between">
      <div>
        <h2 class="text-3xl md:text-4xl text-white mb-3">Paquetes</h2>
        <div class="w-12 h-px bg-white/40"></div>
      </div>
      {preview && (
        <a
          href="/paquetes/"
          class="hidden sm:inline-flex items-center gap-2 text-sm text-white/40 hover:text-white transition-colors duration-200 uppercase tracking-wider focus-visible:outline-2 focus-visible:outline-white"
        >
          Ver todos
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      )}
    </div>

    {byService.map(({ service, pkgs }) => (
      <div class="mb-16 last:mb-0">

        {!preview && (
          <p class="text-xs uppercase tracking-[0.3em] text-white/25 mb-8">{service.title}</p>
        )}

        <div class:list={[
          'grid gap-px bg-white/8',
          pkgs.length >= 3 ? 'grid-cols-1 md:grid-cols-3' : 'grid-cols-1 md:grid-cols-2',
        ]}>
          {pkgs.map((pkg, i) => (
            <div class="relative flex flex-col p-8 bg-[#070707] overflow-hidden transition-colors duration-300 hover:bg-white/3 group">

              {/* Big editorial background number */}
              <span
                class="absolute bottom-5 right-6 text-white/5 font-bold leading-none select-none pointer-events-none"
                style="font-size: clamp(5rem, 10vw, 7rem); font-family: 'Playfair Display', Georgia, serif; font-style: italic;"
                aria-hidden="true"
              >
                {String(i + 1).padStart(2, '0')}
              </span>

              <div class="relative z-10 flex flex-col flex-1">

                <h4 class="text-2xl md:text-3xl text-white mb-3 leading-tight">
                  {pkg.name}
                </h4>

                <p class="text-sm text-white/50 mb-8 leading-relaxed">
                  {pkg.description}
                </p>

                <ul class="space-y-3 mb-10 flex-1">
                  {pkg.includes.map(item => (
                    <li class="flex items-start gap-3 text-sm">
                      <svg
                        class="w-3.5 h-3.5 mt-0.5 shrink-0 text-white/35"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      <span class="text-white/65">{item}</span>
                    </li>
                  ))}
                </ul>

                <a
                  href={`https://wa.me/50685546933?text=${encodeURIComponent(`Hola Isaías, me interesa el paquete *${pkg.name}* de ${service.title}.`)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="border border-white/25 text-white text-center px-5 py-3 text-sm uppercase tracking-wider font-semibold transition-all duration-300 hover:border-white hover:bg-white hover:text-black min-h-11 flex items-center justify-center focus-visible:outline-2 focus-visible:outline-white"
                >
                  Consultar
                </a>

              </div>
            </div>
          ))}
        </div>

      </div>
    ))}

    {/* Mobile only — ver todos */}
    {preview && (
      <div class="mt-8 text-center sm:hidden">
        <a
          href="/paquetes/"
          class="inline-flex items-center gap-2 px-7 py-3 border border-white/30 text-white text-sm uppercase tracking-wider transition-all duration-300 hover:border-white hover:bg-white hover:text-black min-h-11 focus-visible:outline-2 focus-visible:outline-white"
        >
          Ver todos los paquetes
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    )}

    {/* Full packages page — personalizado CTA */}
    {!preview && (
      <div class="mt-16 py-12 border-t border-white/8 text-center">
        <p class="text-white/35 text-sm mb-6">¿Tenés algo en mente que no está listado?</p>
        <a
          href={`https://wa.me/50685546933?text=${encodeURIComponent('Hola Isaías, me gustaría consultar sobre un paquete personalizado.')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-3.5 bg-white text-black text-sm uppercase tracking-wider font-semibold transition-all duration-300 hover:bg-white/90 hover:scale-105 min-h-11 focus-visible:outline-2 focus-visible:outline-white"
        >
          Consultar paquete personalizado
        </a>
      </div>
    )}

  </div>
</section>
