---
import Layout from "../layouts/Layout.astro";
import Contact from "@/components/Contact.astro";
---

<Layout
  title="Contacto — Fotografía en San José, Costa Rica"
  description="Contactá a Photographic Images, fotografía profesional en San José. WhatsApp: +506 8554-6933. Bodas, retratos, eventos, bautizos y sacramentos."
>
  <section class="pt-12 pb-0 bg-black">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white uppercase tracking-wide mb-4">
        Fotógrafo Profesional en San José, Costa Rica
      </h1>
      <div class="w-12 h-px bg-white/40 mx-auto mb-6"></div>
      <p class="text-white/55">
        Bodas, retratos, eventos, bautizos y sacramentos en todo el país. Escribime por WhatsApp o email — respondo en el día.
      </p>
    </div>
  </section>

  <Contact />
</Layout>
