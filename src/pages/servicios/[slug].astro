---
import Layout from "../../layouts/Layout.astro";
import Packages from "@/components/Packages.astro";
import ServiceGalleryCarousel from "@/components/ServiceGalleryCarousel.astro";
import ServiceHeroCarousel from "@/components/ServiceHeroCarousel.astro";
import { getServiceBySlug, getPackages } from '@/lib/db'
import { cldOptimize } from '@/lib/cloudinary'

const { slug } = Astro.params
const service = await getServiceBySlug(slug!)

if (!service) {
  return Astro.redirect('/servicios/')
}

// Universal packages (service_id null) + any specific to this service
const associatedPkgs = await getPackages(service.id)
const hasPackages = associatedPkgs.length > 0

const paragraphs = (service.detailed_description ?? service.description)
  .split('\n\n')
  .filter(Boolean)

const hasGallery = !!service.gallery && service.gallery.length > 0
const showHeroCarousel = service.use_carousel && hasGallery
---

<Layout
  title={`${service.title} en Costa Rica`}
  description={service.description}
  image={service.image}
>

  {/* ── Hero ── */}
  <div class="svc-hero relative overflow-hidden bg-black">

    {/* Background image / carrusel */}
    {showHeroCarousel ? (
      <ServiceHeroCarousel images={service.gallery!} alt={service.title} />
    ) : (
      <img
        src={cldOptimize(service.image, 1200, 700)}
        alt={service.title}
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
        width="1200"
        height="700"
      />
    )}

    {/* Gradient overlays */}
    <div class="absolute inset-0 bg-linear-to-t from-black via-black/55 to-black/25" aria-hidden="true" />
    <div class="absolute inset-0 bg-linear-to-r from-black/60 via-transparent to-transparent" aria-hidden="true" />

    {/* Content */}
    <div class="relative z-10 h-full flex flex-col justify-end px-6 md:px-12 pb-12 md:pb-16 pt-32 max-w-6xl mx-auto w-full">

      {/* Back link */}
      <a
        href="/servicios/"
        class="inline-flex items-center gap-2 text-white/60 hover:text-white text-xs uppercase tracking-widest transition-colors duration-200 mb-8 self-start focus-visible:outline-2 focus-visible:outline-white"
      >
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
        </svg>
        Todos los servicios
      </a>

      <p class="text-[0.6rem] uppercase tracking-[0.35em] text-white/60 mb-4">
        Photographic Chagui — Servicio
      </p>

      <h1
        class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl text-white leading-none max-w-2xl"
        style="font-family: 'Playfair Display', Georgia, serif; font-style: italic;"
      >
        {service.title}
        <span class="block text-xl md:text-2xl text-white/50 mt-3 not-italic tracking-widest uppercase" style="font-family: inherit; font-style: normal; font-size: clamp(0.85rem, 2vw, 1.15rem);">
          en Costa Rica
        </span>
      </h1>

      <div class="w-12 h-px bg-white/40 mt-6"></div>
    </div>

  </div>

  {/* ── Galería ── */}
  {service.gallery && service.gallery.length > 0 && (
    <section class="py-16 md:py-20 bg-black border-t border-white/8">
      <div class="max-w-6xl mx-auto px-6 md:px-4">

        <div class="mb-10">
          <div class="flex items-baseline gap-3">
            <p class="text-[0.6rem] uppercase tracking-[0.35em] text-white/50">Galería</p>
            <span class="font-mono text-[10px] text-white/50">{String(service.gallery.length).padStart(2, '0')} fotos</span>
          </div>
          <h2
            class="text-2xl md:text-3xl text-white mt-3"
            style="font-family: 'Playfair Display', Georgia, serif; font-style: italic;"
          >
            Trabajos de {service.title}
          </h2>
          <div class="w-12 h-px bg-white/40 mt-4"></div>
        </div>

        <ServiceGalleryCarousel images={service.gallery} />
      </div>
    </section>
  )}

  {/* ── Content ── */}
  <section class="py-16 md:py-24 bg-black">
    <div class="max-w-6xl mx-auto px-6 md:px-4">

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">

        {/* Left — description + CTA */}
        <div>
          <div class="space-y-5 mb-10">
            {paragraphs.map((p: string) => (
              <p class="text-white/65 leading-relaxed text-base md:text-lg">{p}</p>
            ))}
          </div>

          <a
            href={`https://wa.me/50685546933?text=${encodeURIComponent(`Hola Isaías, me interesa el servicio de ${service.title}.`)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 px-7 py-3.5 bg-white text-black text-sm uppercase tracking-wider font-semibold transition-all duration-200 hover:bg-white/90 min-h-11 focus-visible:outline-2 focus-visible:outline-white"
          >
            Consultar disponibilidad
          </a>
        </div>

        {/* Right — features */}
        {service.features.length > 0 && (
          <div>
            <p class="text-[0.6rem] uppercase tracking-[0.3em] text-white/60 mb-8">Qué incluye</p>
            <ul class="space-y-0">
              {service.features.map((feature: string, fi: number) => (
                <li class="flex items-start gap-5 py-4 border-b border-white/8 group/feat">
                  <span
                    class="text-white/15 font-mono text-xs tracking-widest shrink-0 pt-0.5 w-5"
                    aria-hidden="true"
                  >
                    {String(fi + 1).padStart(2, '0')}
                  </span>
                  <span class="text-white/60 group-hover/feat:text-white/85 text-sm md:text-base leading-relaxed transition-colors duration-300">
                    {feature}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        )}

      </div>
    </div>
  </section>

  {/* ── FAQ ── */}
  {service.faqs && service.faqs.length > 0 && (
    <section class="py-16 md:py-20 bg-[#070707] border-t border-white/8">
      <div class="max-w-6xl mx-auto px-6 md:px-4">

        <div class="mb-12">
          <p class="text-[0.6rem] uppercase tracking-[0.35em] text-white/50 mb-3">Preguntas frecuentes</p>
          <h2
            class="text-2xl md:text-3xl text-white"
            style="font-family: 'Playfair Display', Georgia, serif; font-style: italic;"
          >
            Preguntas sobre {service.title}
          </h2>
          <div class="w-12 h-px bg-white/40 mt-4"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
          {service.faqs.map((faq: { q: string; a: string }) => (
            <div class="border-l border-white/15 pl-6">
              <h3 class="text-white text-base font-medium mb-3 leading-snug">
                {faq.q}
              </h3>
              <p class="text-white/65 text-sm leading-relaxed">{faq.a}</p>
            </div>
          ))}
        </div>

      </div>
    </section>
  )}

  {/* ── Packages ── */}
  {hasPackages && (
    <div class="bg-[#070707] border-t border-white/8">
      <div class="max-w-6xl mx-auto px-4 pt-12 md:pt-16">
        <div class="flex items-end justify-between mb-10">
          <div>
            <p class="text-[0.6rem] uppercase tracking-[0.3em] text-white/60 mb-3">
              Precios — aplica para este servicio
            </p>
            <h2
              class="text-2xl md:text-3xl text-white"
              style="font-family: 'Playfair Display', Georgia, serif; font-style: italic;"
            >
              Paquetes
            </h2>
            <div class="w-12 h-px bg-white/40 mt-3"></div>
          </div>
          <a
            href="/paquetes/"
            class="hidden sm:inline-flex items-center gap-2 text-xs text-white/60 hover:text-white uppercase tracking-widest transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-white"
          >
            Ver todos
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
      <Packages showHeader={false} serviceId={service.id} />
    </div>
  )}

  {/* ── Navigation between services ── */}
  <section class="py-14 bg-black border-t border-white/8">
    <div class="max-w-6xl mx-auto px-4 flex items-center justify-between">
      <a
        href="/servicios/"
        class="inline-flex items-center gap-2 text-white/60 hover:text-white text-xs uppercase tracking-widest transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-white"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
        </svg>
        Todos los servicios
      </a>

      <a
        href="/#contacto"
        class="inline-flex items-center gap-2 px-6 py-3 border border-white/20 text-white/70 text-xs uppercase tracking-widest transition-all duration-300 hover:border-white hover:text-white min-h-11 focus-visible:outline-2 focus-visible:outline-white"
      >
        Contactar →
      </a>
    </div>
  </section>

</Layout>

<style>
  .svc-hero {
    height: 65vh;
    min-height: 420px;
  }
</style>
