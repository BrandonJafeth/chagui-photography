---
// TODO: migrar a Supabase — tabla site_content (keys: about_*)
import Layout from "../layouts/Layout.astro";
import { getContent } from "@/data/site-content";

const aboutText   = getContent('about_text')
const imageUrl    = getContent('about_image_url')
const paragraphs  = aboutText.split('\n\n').filter(Boolean)
---

<Layout
  title="Sobre mí — Fotógrafo en San José, Costa Rica"
  description="Conocé a Photographic Images, fotografía profesional en San José, Costa Rica. Bodas, retratos y eventos con mirada propia."
>
  <section class="py-24 px-4 bg-black min-h-screen">
    <div class="max-w-5xl mx-auto">

      <div class="mb-16">
        <h1 class="text-4xl md:text-5xl lg:text-6xl text-white leading-none mb-3"
            style="font-family: 'Playfair Display', Georgia, serif; font-style: italic;">
          Sobre mí
        </h1>
        <div class="w-12 h-px bg-white/40"></div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        {/* Polaroid */}
        <div class="flex justify-center lg:justify-start">
          <div class="polaroid-stack w-full max-w-xs sm:max-w-sm">
            <div class="polaroid-card">
              <div class="polaroid-inner">
                <img
                  src={imageUrl}
                  alt="Isaías Díaz García — fotógrafo profesional en San José, Costa Rica"
                  class="w-full h-full object-cover object-top"
                  loading="eager"
                  width="400"
                  height="500"
                />
              </div>
            </div>
            <div class="polaroid-back" aria-hidden="true"></div>
          </div>
        </div>

        {/* Bio */}
        <div class="space-y-6">
          {paragraphs.map(p => (
            <p class="text-white/70 leading-relaxed text-base md:text-[1.05rem]">{p}</p>
          ))}

          <div class="pt-4 space-y-3 border-t border-white/10">
            <div class="flex items-center gap-3 text-sm">
              <span class="text-white/35 uppercase tracking-wider text-xs">WhatsApp</span>
              <a href="https://wa.me/50685546933" target="_blank" rel="noopener noreferrer"
                 class="text-white hover:text-white/70 transition-colors">
                +506 8554-6933
              </a>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <span class="text-white/35 uppercase tracking-wider text-xs">Email</span>
              <a href="mailto:isaiasdg14@hotmail.com"
                 class="text-white hover:text-white/70 transition-colors">
                isaiasdg14@hotmail.com
              </a>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <span class="text-white/35 uppercase tracking-wider text-xs">Zona</span>
              <span class="text-white">San José · Gran Área Metropolitana</span>
            </div>
          </div>

          <div class="pt-6">
            <a
              href="/#contacto"
              class="inline-flex items-center gap-2 px-6 py-3 bg-white text-black font-semibold text-sm uppercase tracking-wider transition-all duration-300 hover:bg-white/90 hover:scale-105 min-h-11"
            >
              Trabajemos juntos
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>

<style>
  .polaroid-stack {
    position: relative;
  }
  .polaroid-card {
    position: relative;
    z-index: 1;
    width: 100%;
    aspect-ratio: 4 / 5;
    background: #0d0d0d;
    border: 3px solid #fff;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.75);
    transition: transform 0.3s ease;
  }
  .polaroid-inner {
    width: 100%;
    height: 100%;
    padding: 4%;
    padding-bottom: 13%;
    background: #0d0d0d;
  }
  .polaroid-inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .polaroid-back {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    aspect-ratio: 4 / 5;
    background: #1a1a1a;
    border: 3px solid rgba(255, 255, 255, 0.55);
    transform: rotate(4deg) translateY(-2%);
    z-index: 0;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  }
  .polaroid-stack:hover .polaroid-card {
    transform: rotate(-2deg);
  }
</style>
