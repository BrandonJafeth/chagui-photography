---
// TODO: migrar a Supabase — tabla services
// Al migrar: query → supabase.from('services').select('*').eq('is_active', true).order('order')
import Layout from "../layouts/Layout.astro";
import { services } from '@/data/services';

const activeServices = services.filter(s => s.is_active).sort((a, b) => a.order - b.order)
---

<Layout
  title="Servicios de Fotografía"
  description="Fotografía profesional de bodas, retratos, eventos, bautizos y sacramentos en Costa Rica. Photographic Images — Isaías Díaz."
>

  {/* ── Header editorial ── */}
  <header class="pt-28 pb-10 bg-black border-b border-white/8">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6">
        <div>
          <p class="text-[0.65rem] uppercase tracking-[0.35em] text-white/30 mb-4">
            Photographic Images
          </p>
          <h1 class="text-4xl md:text-5xl lg:text-6xl text-white leading-none"
              style="font-family: 'Playfair Display', Georgia, serif; font-style: italic;">
            Servicios
          </h1>
          <div class="w-12 h-px bg-white/40 mt-4"></div>
        </div>
        <p class="text-white/45 text-sm max-w-xs leading-relaxed sm:text-right">
          Fotografía profesional para cada momento.<br />
          Disponible en San José y el Gran Área Metropolitana.
        </p>
      </div>
    </div>
  </header>

  {/* ── Service list ── */}
  <section class="bg-black">
    <div class="max-w-6xl mx-auto px-4">
      {activeServices.map((service) => (
        <a
          href={`/servicios/${service.slug}/`}
          class="group flex items-center gap-6 md:gap-10 py-6 md:py-8 border-b border-white/8 transition-colors duration-200 hover:bg-white/2.5 hover:border-white/15 focus-visible:outline-2 focus-visible:outline-white"
        >

          {/* Image */}
          <div class="hidden md:block shrink-0 overflow-hidden w-28 lg:w-36 h-18 lg:h-22">
            <img
              src={service.image}
              alt={service.title}
              class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              loading="lazy"
              width="144"
              height="88"
            />
          </div>

          {/* Title + description */}
          <div class="flex-1 min-w-0">
            <h2
              class="text-xl md:text-2xl lg:text-3xl text-white/75 group-hover:text-white transition-colors duration-200 leading-tight"
              style="font-family: 'Playfair Display', Georgia, serif; font-style: italic;"
            >
              {service.title}
            </h2>
            <p class="text-white/35 group-hover:text-white/55 text-sm mt-1.5 leading-relaxed line-clamp-1 transition-colors duration-200 max-w-xl">
              {service.description}
            </p>
          </div>

          {/* Arrow */}
          <svg
            class="w-4 h-4 text-white/20 group-hover:text-white/65 transition-all duration-200 shrink-0 group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
            fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7v10" />
          </svg>

        </a>
      ))}
    </div>
  </section>

  {/* ── Bottom CTA ── */}
  <section class="py-20 bg-black border-t border-white/8 mt-0">
    <div class="max-w-6xl mx-auto px-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
      <div>
        <p
          class="text-white text-xl md:text-2xl leading-snug"
          style="font-family: 'Playfair Display', Georgia, serif; font-style: italic;"
        >
          ¿No encontrás lo que buscás?
        </p>
        <p class="text-white/40 text-sm mt-2">
          Consultá por un servicio personalizado.
        </p>
      </div>
      <a
        href={`https://wa.me/50685546933?text=${encodeURIComponent('Hola Isaías, quisiera consultar sobre un servicio personalizado.')}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-7 py-3.5 bg-white text-black text-sm uppercase tracking-wider font-semibold transition-all duration-200 hover:bg-white/90 min-h-11 focus-visible:outline-2 focus-visible:outline-white shrink-0"
      >
        Consultar por WhatsApp
      </a>
    </div>
  </section>

</Layout>

