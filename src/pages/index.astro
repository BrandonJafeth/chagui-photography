---
import Layout from "../layouts/Layout.astro";
import Hero from "@/components/Hero.astro";
import MarqueeStrip from "@/components/MarqueeStrip.astro";
import About from "@/components/About.astro";
import ServicesOverview from "@/components/ServicesOverview.astro";
import QuoteBreak from "@/components/QuoteBreak.astro";
import Packages from "@/components/Packages.astro";
import Testimonials from "@/components/Testimonials.astro";
import Contact from "@/components/Contact.astro";
---

<Layout
  title="Fotografía Profesional en San José, Costa Rica"
  description="Photographic Images — fotografía profesional en San José, Costa Rica. Bodas, retratos, eventos, bautizos y sacramentos con mirada propia."
>
  <Hero />
  <MarqueeStrip />
  <About />
  <ServicesOverview />
  <QuoteBreak />
  <Packages preview={true} />
  <Testimonials />
  <Contact />
</Layout>
